RewriteEngine On

# Allow access to actual files/directories (like uploaded images)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Check if .php equivalent exists and rewrite
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*)$ $1.php [L,QSA]

# FORCE Redirect .php to clean URL (prevents seeing .php in browser)
RewriteCond %{THE_REQUEST} \s/+(?:web_fikom/)?admin/([^.]+)\.php[\s?] [NC]
RewriteRule ^ %1 [R=301,L]
